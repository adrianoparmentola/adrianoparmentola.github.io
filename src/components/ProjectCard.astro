---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getProjectAsset } from '../lib/images';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  meta: CollectionEntry<'projectMeta'>;
  title: string;
  lang: Lang;
  // Proporzione della finestra: decisa dal layout (griglia asimmetrica),
  // in relazione a formato e livello di dettaglio del media mostrato.
  aspect?: 'landscape' | 'standard' | 'portrait' | 'square';
}

const { meta, title, lang, aspect = 'standard' } = Astro.props;
const t = useTranslations(lang);
const slug = meta.id;
const heroAsset = meta.data.assets.find((a) => a.role === 'hero') ?? meta.data.assets[0];
// Media della card: priorità al ruolo esplicito "thumb" (immagine O video in
// loop), poi all'hero se è un'immagine, altrimenti la prima immagine.
const thumbAsset =
  meta.data.assets.find((a) => a.role === 'thumb') ??
  (heroAsset?.kind === 'image' ? heroAsset : meta.data.assets.find((a) => a.kind === 'image'));
const thumbImage =
  thumbAsset?.kind === 'image' ? getProjectAsset(slug, thumbAsset.src) : undefined;
const thumbVideo = thumbAsset?.kind === 'video' ? thumbAsset.src : undefined;
---

<a class:list={['project-card', aspect]} href={`/${lang}/projects/${slug}/`}>
  <div class="thumb">
    {thumbImage && (
      <Image src={thumbImage} alt={title} widths={[400, 800, 1400]} sizes="(max-width: 768px) 100vw, 50vw" />
    )}
    {thumbVideo && <video src={thumbVideo} autoplay muted loop playsinline aria-hidden="true"></video>}
    {heroAsset?.kind === 'model' && <div class="model-badge meta-tag">3D</div>}
  </div>
  <div class="info">
    <h3>{title}</h3>
    <div class="tags">
      {meta.data.year && <span class="meta-tag">{meta.data.year}</span>}
      {meta.data.status === 'demo' && <span class="meta-tag">{t('projects.demoLabel')}</span>}
      {meta.data.methodTags.map((tag) => <span class="meta-tag tag">{tag}</span>)}
    </div>
  </div>
</a>

<style>
  .project-card {
    display: block;
    color: var(--color-text);
  }

  .thumb {
    position: relative;
    overflow: hidden;
    background: var(--color-border);
    aspect-ratio: 4 / 3;
  }

  .project-card.landscape .thumb {
    aspect-ratio: 16 / 10;
  }

  .project-card.portrait .thumb {
    aspect-ratio: 3 / 4;
  }

  .project-card.square .thumb {
    aspect-ratio: 1 / 1;
  }

  .thumb :global(img),
  .thumb video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .project-card:hover .thumb :global(img),
  .project-card:hover .thumb video {
    transform: scale(1.03);
  }

  .model-badge {
    position: absolute;
    top: var(--space-1);
    right: var(--space-1);
    background: var(--color-accent);
    color: var(--color-text);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
  }

  .info {
    padding-top: var(--space-1);
  }

  h3 {
    font-size: var(--text-h3);
    margin-bottom: 0.25rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tags .tag {
    color: var(--color-text-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .thumb :global(img),
    .thumb video {
      transition: none;
    }
  }
</style>
