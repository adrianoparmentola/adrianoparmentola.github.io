---
import { languages, useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// "Metodo" volutamente fuori dalla top bar (resta raggiungibile dalla CTA
// della home e dalle pagine progetto). Vedi NOTES.md.
const links = [
  { href: `/${lang}/`, label: t('nav.home') },
  { href: `/${lang}/projects/`, label: t('nav.projects') },
  { href: `/${lang}/cases/`, label: t('nav.cases') },
  { href: `/${lang}/contact/`, label: t('nav.contact') },
];

const currentPath = Astro.url.pathname.replace(new RegExp(`^/${lang}/`), '/');
---

<header class="site-nav">
  <a class="brand" href={`/${lang}/`}>Adriano Parmentola</a>
  <nav aria-label="Main">
    <ul>
      {
        links.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))
      }
    </ul>
  </nav>
  <div class="lang-switch" aria-label="Language">
    {
      Object.keys(languages).map((code) => (
        <a
          href={`/${code}${currentPath}`}
          aria-current={code === lang ? 'true' : undefined}
        >
          {code.toUpperCase()}
        </a>
      ))
    }
  </div>
</header>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    max-width: var(--content-max-width);
    margin: 0 auto;
    flex-wrap: wrap;
  }

  .brand {
    font-weight: var(--weight-bold);
    font-size: var(--text-meta);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  nav ul {
    display: flex;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  nav a {
    font-weight: var(--weight-bold);
    font-size: var(--text-meta);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .lang-switch {
    display: flex;
    gap: var(--space-1);
    font-size: var(--text-meta);
    font-weight: var(--weight-bold);
  }

  .lang-switch a[aria-current='true'] {
    color: var(--color-accent);
  }
</style>
